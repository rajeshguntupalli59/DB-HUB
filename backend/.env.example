# DB Hub — Backend Configuration
# Copy this file to .env and fill in your values

# JWT secret — generate a strong random string (python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key

# JWT expiry (default 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite:///./db_hub.sqlite3

# Fernet encryption key for stored DB passwords
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_with_fernet

# Anthropic API key — required for AI Assistant and Documentation modules
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# License bypass — for development/testing only. Remove in production.
# LICENSE_KEY=DEV
